timestamp: 2026-05-26T20:57:04.835+00:00
chip_kind: GithubPullRequest
chip_title: GitHub Pull Request
phase: value
shell_type: Bash
working_directory: /tmp/warpctrl-validation-coordinator/home
status: success
timed_out: false
exit_code: 0
command:
<<<COMMAND
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0
git symbolic-ref --quiet --short HEAD >/dev/null 2>&1 || exit 0

remote_url=$(git remote get-url origin 2>/dev/null) || exit 0
case "$remote_url" in
    git@github.com:*|https://github.com/*|http://github.com/*|ssh://git@github.com/*)
        ;;
    *)
        exit 0
        ;;
esac

output=$(gh pr view --json url --jq .url 2>&1)
exit_code=$?

if [ $exit_code -eq 0 ]; then
    printf '%s\n' "$output"
else
    case "$output" in
        *'no pull requests found for branch '*|*'no open pull requests found for branch '*)
            exit 0
            ;;
    esac
    printf '%s\n' "$output" >&2
    exit $exit_code
fi
>>>COMMAND

stdout:
<<<STDOUT
<empty>
>>>STDOUT

stderr:
<<<STDERR
<empty>
>>>STDERR

